generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum CampaignStatus {
  ACTIVE
  ARCHIVED
}

enum NpcType {
  STANDARD
  COMPANION
}

enum EncounterDifficulty {
  EASY
  MEDIUM
  HARD
  DEADLY
  BOSS
}

enum HoldingScope {
  INVENTORY
  BANK
}

enum LedgerEntryType {
  AWARD
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  PURCHASE
  QUEST_REWARD
  CRAFTING_INPUT
  CRAFTING_OUTPUT
}

enum LootRarity {
  COMMON
  UNCOMMON
  RARE
  VERY_RARE
  LEGENDARY
}

enum LootKind {
  ARMOR
  WEAPON
  WONDROUS
  CONSUMABLE
  TOOL
  TREASURE
}

enum LootPoolStatus {
  OPEN
  BANKED
  RESOLVED
  ARCHIVED
}

enum LootPoolItemStatus {
  UNRESOLVED
  BANKED
  ASSIGNED
  ROLLED
}

enum LootDistributionMode {
  ASSIGN
  ROLL
  BANK
}

enum LootPoolRollStatus {
  ELIGIBLE
  ROLLED
  WON
  LOST
  PASSED
}

enum LootReservationEventType {
  RESERVED
  CLEARED
  RELEASED
  AWARDED
}

enum MonsterSourceType {
  SRD
  OPEN
  CUSTOM
}

enum CompendiumSourceProvider {
  OPEN5E
  DND5EAPI
}

enum QuestStatus {
  OPEN
  ACTIVE
  COMPLETE
  ARCHIVED
}

enum StorefrontStatus {
  ACTIVE
  ARCHIVED
}

enum MailThreadStatus {
  ACTIVE
  ARCHIVED
}

enum CraftingRecipeStatus {
  ACTIVE
  ARCHIVED
}

enum CraftingJobStatus {
  DRAFT
  IN_PROGRESS
  COMPLETE
  ARCHIVED
}

enum CraftingResolutionOutcome {
  SUCCESS
  MIXED
  FAILURE
}

model Campaign {
  id                String                  @id @default(cuid())
  slug              String                  @unique
  name              String
  status            CampaignStatus          @default(ACTIVE)
  setting           String
  summary           String
  sessionNight      String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  characters        Character[]
  npcs              Npc[]
  monsters          MonsterCompendiumEntry[]
  encounters        Encounter[]
  lootItems         LootItem[]
  lootPools         LootPool[]
  quests            Quest[]
  storefronts       Storefront[]
  mailThreads       MailThread[]
  craftingRecipes   CraftingRecipe[]
  craftingJobs      CraftingJob[]
  bankLoginAttempts BankLoginAttempt[]
  ledgerEntries     InventoryLedgerEntry[]
  reservationEvents LootReservationEvent[]
}

model Character {
  id            String                 @id @default(cuid())
  campaignId    String
  name          String
  classRole     String
  level         Int
  playerName    String
  notes         String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  campaign      Campaign               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  bankAccess    BankAccess?
  quests        Quest[]                @relation("QuestAssignee")
  craftingJobs  CraftingJob[]          @relation("CraftingJobCharacter")
  lootPoolAwards LootPoolItem[]        @relation("LootPoolAwardedCharacter")
  lootPoolRolls LootPoolRollEntry[]    @relation("LootPoolRollCharacter")
  ledgerEntries InventoryLedgerEntry[]
  reservationEvents LootReservationEvent[] @relation("LootReservationEventCharacter")

  @@unique([campaignId, name])
}

model BankAccess {
  id               String    @id @default(cuid())
  characterId      String    @unique
  pinHash          String
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model BankLoginAttempt {
  id                 String    @id @default(cuid())
  campaignId         String
  characterNameKey   String
  failedAttemptCount Int       @default(0)
  lockedUntil        DateTime?
  lastAttemptAt      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  campaign           Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, characterNameKey])
}

model Npc {
  id                String    @id @default(cuid())
  campaignId        String
  name              String
  title             String?
  type              NpcType   @default(STANDARD)
  tags              String    @default("")
  surfaceBlurb      String
  tableHooks        String
  persistentNotes   String
  faction           String?
  relationshipNotes String?
  isArchived        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  campaign          Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model MonsterCompendiumEntry {
  id                String            @id @default(cuid())
  campaignId        String?
  sourceKey         String?
  sourceUrl         String?
  sourceDocument    String?
  compendiumSource  CompendiumSourceProvider?
  name              String
  challengeRating   String
  monsterType       String
  environment       String
  tags              String            @default("")
  specialDrops      String            @default("")
  source            MonsterSourceType @default(SRD)
  isCustom          Boolean           @default(false)
  basedOnName       String?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  campaign          Campaign?         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  encounterMonsters EncounterMonster[]

  @@unique([campaignId, sourceKey])
}

model Encounter {
  id          String               @id @default(cuid())
  campaignId  String
  title       String
  difficulty  EncounterDifficulty
  partyLevel  Int
  notes       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  campaign    Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  monsters    EncounterMonster[]
  lootPools   LootPool[]
}

model EncounterMonster {
  id          String                 @id @default(cuid())
  encounterId String
  monsterId   String
  quantity    Int                    @default(1)
  notes       String?
  encounter   Encounter              @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  monster     MonsterCompendiumEntry @relation(fields: [monsterId], references: [id], onDelete: Cascade)
}

model LootItem {
  id             String                 @id @default(cuid())
  campaignId     String
  sourceKey      String?
  sourceUrl      String?
  sourceDocument String?
  compendiumSource CompendiumSourceProvider?
  name           String
  rarity         LootRarity
  kind           LootKind
  description    String
  notes          String?
  sourceTag      String?
  goldValue      Int?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  campaign       Campaign               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ledgerEntries  InventoryLedgerEntry[] @relation("LootItemLedgerEntries")
  lootPoolItems  LootPoolItem[]
  craftingJobs   CraftingJob[]          @relation("CraftingJobLootItem")
  storefrontOffers StorefrontOffer[]     @relation("StorefrontOfferLootItem")

  @@unique([campaignId, sourceKey])
}

model LootPool {
  id          String             @id @default(cuid())
  campaignId  String
  encounterId String?
  title       String
  sourceText  String?
  notes       String?
  partyLevel  Int
  difficulty  EncounterDifficulty?
  status      LootPoolStatus     @default(OPEN)
  resolvedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  campaign    Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  encounter   Encounter?         @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  items       LootPoolItem[]
}

model LootPoolItem {
  id                 String             @id @default(cuid())
  lootPoolId         String
  lootItemId         String?
  awardedCharacterId String?
  itemNameSnapshot   String
  raritySnapshot     LootRarity
  kindSnapshot       LootKind
  quantity           Int                @default(1)
  distributionMode   LootDistributionMode @default(ASSIGN)
  status             LootPoolItemStatus @default(UNRESOLVED)
  resolutionScope    HoldingScope?
  resolutionNote     String?
  resolutionMetadata String?
  resolvedAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  lootPool           LootPool           @relation(fields: [lootPoolId], references: [id], onDelete: Cascade)
  lootItem           LootItem?          @relation(fields: [lootItemId], references: [id], onDelete: SetNull)
  awardedCharacter   Character?         @relation("LootPoolAwardedCharacter", fields: [awardedCharacterId], references: [id], onDelete: SetNull)
  rollEntries        LootPoolRollEntry[]
  reservationEvents  LootReservationEvent[]
}

model LootReservationEvent {
  id            String                   @id @default(cuid())
  campaignId    String
  lootPoolItemId String
  characterId   String?
  eventType     LootReservationEventType
  note          String
  createdAt     DateTime                 @default(now())
  campaign      Campaign                 @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lootPoolItem  LootPoolItem             @relation(fields: [lootPoolItemId], references: [id], onDelete: Cascade)
  character     Character?               @relation("LootReservationEventCharacter", fields: [characterId], references: [id], onDelete: SetNull)
}

model LootPoolRollEntry {
  id             String             @id @default(cuid())
  lootPoolItemId String
  characterId    String
  rollTotal      Int?
  status         LootPoolRollStatus @default(ELIGIBLE)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  lootPoolItem   LootPoolItem       @relation(fields: [lootPoolItemId], references: [id], onDelete: Cascade)
  character      Character          @relation("LootPoolRollCharacter", fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([lootPoolItemId, characterId])
}

model Quest {
  id                  String       @id @default(cuid())
  campaignId          String
  assigneeCharacterId String?
  title               String
  objective           String
  rewardGold          Int          @default(0)
  rewardText          String?
  status              QuestStatus  @default(OPEN)
  notes               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  campaign            Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  assignee            Character?   @relation("QuestAssignee", fields: [assigneeCharacterId], references: [id], onDelete: SetNull)
}

model Storefront {
  id          String            @id @default(cuid())
  campaignId  String
  name        String
  keeperName  String?
  description String
  status      StorefrontStatus  @default(ACTIVE)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  campaign    Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  offers      StorefrontOffer[]
}

model StorefrontOffer {
  id              String      @id @default(cuid())
  storefrontId    String
  lootItemId      String?
  itemName        String
  itemDescription String
  rarity          LootRarity
  kind            LootKind
  priceGold       Int
  quantity        Int         @default(1)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  storefront      Storefront  @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
  lootItem        LootItem?   @relation("StorefrontOfferLootItem", fields: [lootItemId], references: [id], onDelete: SetNull)
}

model MailThread {
  id            String           @id @default(cuid())
  campaignId    String
  subject       String
  senderName    String
  recipientName String
  status        MailThreadStatus @default(ACTIVE)
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  campaign      Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  messages      MailMessage[]
}

model MailMessage {
  id         String     @id @default(cuid())
  threadId   String
  fromName   String
  toName     String
  body       String
  isFromDm   Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  thread     MailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model CraftingRecipe {
  id               String                @id @default(cuid())
  campaignId       String
  name             String
  outputName       String
  outputDescription String
  outputRarity     LootRarity
  outputKind       LootKind
  inputText        String
  materialsText    String                @default("")
  goldCost         Int                   @default(0)
  timeText         String?
  notes            String?
  status           CraftingRecipeStatus  @default(ACTIVE)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  campaign         Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  jobs             CraftingJob[]
}

model CraftingJob {
  id                String                     @id @default(cuid())
  campaignId        String
  recipeId          String?
  characterId       String?
  lootItemId        String?
  status            CraftingJobStatus         @default(DRAFT)
  resolutionOutcome CraftingResolutionOutcome?
  resolutionText    String?
  rollDie           Int?
  rollTotal         Int?
  resolvedAt        DateTime?
  notes             String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  campaign          Campaign                   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  recipe            CraftingRecipe?            @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  character         Character?                 @relation("CraftingJobCharacter", fields: [characterId], references: [id], onDelete: SetNull)
  lootItem          LootItem?                  @relation("CraftingJobLootItem", fields: [lootItemId], references: [id], onDelete: SetNull)
}

model InventoryLedgerEntry {
  id          String          @id @default(cuid())
  campaignId  String
  characterId String
  lootItemId  String?
  scope       HoldingScope
  entryType   LedgerEntryType
  quantity    Int             @default(0)
  goldDelta   Int             @default(0)
  note        String
  createdAt   DateTime        @default(now())
  campaign    Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  character   Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  lootItem    LootItem?       @relation("LootItemLedgerEntries", fields: [lootItemId], references: [id], onDelete: SetNull)
}
